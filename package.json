{
  "name": "promptiq",
  "version": "0.1.1",
  "description": "Prompt analytics CLI for Claude Code — captures, scores, and tracks prompt quality over time",
  "bin": {
    "promptiq": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format cjs --dts --out-dir dist",
    "dev": "tsup src/cli.ts --format cjs --watch",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "anthropic",
    "claude",
    "prompt",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
